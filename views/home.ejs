<%- include('partials/head', { title }) %>
<%- include('partials/navbar') %>

<main>
  <section class="hero">
    <div class="shell hero-grid">
      <div>
        <p class="kicker">Modern Dynamic Website</p>
        <h1>Build, manage, and scale your digital catalog from one dashboard.</h1>
        <p>Responsive storefront for users, powerful admin tools for your team, and API-first architecture for integrations.</p>
        <div class="hero-actions">
          <a href="/products" class="btn">Browse Products</a>
          <a href="/admin" class="btn-outline">Open Dashboard</a>
        </div>
      </div>
      <div class="hero-panel card">
        <h3>What you get</h3>
        <ul>
          <li>Role-based authentication</li>
          <li>Product and category CRUD</li>
          <li>Image uploads and searchable catalog</li>
          <li>Dashboard stats with charts</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="shell section">
    <div class="section-head">
      <h2>Featured Products</h2>
      <a href="/products">View all</a>
    </div>

    <div class="grid cards-grid">
      <% featuredProducts.forEach((item) => { %>
        <% const isFree = !item.price || Number(item.price) === 0; %>
        <article class="card product-card">
          <div class="product-media">
            <img src="<%= item.image || 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=1200' %>" alt="<%= item.title %>" />
            <% if (isFree) { %>
              <span class="badge-free">Free</span>
            <% } %>
            <% if (item.video) { %>
              <div class="media-badge">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polygon points="23 7 16 12 23 17 23 7"></polygon>
                  <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
                </svg>
              </div>
            <% } %>
          </div>
          <div>
            <p class="tag"><%= item.category ? item.category.name : 'General' %></p>
            <h3><%= item.title %></h3>
            <p><%= item.description.slice(0, 90) %>...</p>
            <p class="price">
              <% if (isFree) { %>
                <span class="price-free">Free</span>
              <% } else { %>
                $<%= Number(item.price).toFixed(2) %>
              <% } %>
            </p>
            <a href="/products/<%= item.id %>" class="btn-inline">Details</a>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
