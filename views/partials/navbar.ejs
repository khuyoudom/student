<header class="site-header">
  <div class="shell nav-wrap">
    <a class="brand" href="/">
      <span class="brand-dot"></span>
      Student
    </a>

    <nav class="main-nav" id="main-nav">
      <div class="menu-head">
        <strong>Navigation</strong>
        <button class="theme-toggle menu-theme-toggle" type="button" aria-label="Toggle light and dark theme" data-theme-toggle>Theme</button>
      </div>

      <a href="/" class="<%= path === '/' ? 'is-active' : '' %>">Home</a>
      <a href="/products" class="<%= path.startsWith('/products') ? 'is-active' : '' %>">Products / Services</a>
      <a href="/about" class="<%= path === '/about' ? 'is-active' : '' %>">About</a>
      <a href="/contact" class="<%= path === '/contact' ? 'is-active' : '' %>">Contact</a>
      <a href="/orders" class="<%= path.startsWith('/orders') ? 'is-active' : '' %>">Orders</a>
      <a href="/admin" class="<%= path.startsWith('/admin') ? 'is-active' : '' %>">Dashboard</a>
      <form action="/logout" method="post" class="menu-logout-form">
        <button type="submit" class="menu-logout-btn">Logout</button>
      </form>
    </nav>

    <button class="menu-backdrop" type="button" aria-label="Close menu" data-menu-backdrop></button>

    <button class="menu-toggle" type="button" aria-label="Toggle navigation" data-menu-toggle>Menu</button>
    <button class="theme-toggle desktop-theme-toggle" type="button" aria-label="Toggle dark mode" data-theme-toggle>Theme</button>
  </div>
</header>
